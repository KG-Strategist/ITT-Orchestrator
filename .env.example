# ITT-Orchestrator Production Environment Configuration
# Copy this file to .env and fill in your production values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
HOST=0.0.0.0
NODE_ENV=production
RUST_LOG=info

# ============================================
# DATABASE CONFIGURATION  
# ============================================

# MongoDB Configuration
MONGODB_URI=mongodb://mongoadmin:mongopass@localhost:27017/?authSource=admin
MONGODB_DATABASE=itt_orchestrator
MONGODB_POOL_SIZE=10

# Neo4j Configuration  
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_default_pwd

# Database Operation Timeout (seconds)
DB_OPERATION_TIMEOUT_SECS=10

# ============================================
# SECURITY & AUTHENTICATION
# ============================================

# JWT Configuration (Secret MUST be 32+ characters)
JWT_SECRET=your-super-secret-32-char-minimum-jwt-signing-key-here
JWT_EXPIRY=24h
JWT_ALGORITHM=HS256
TOKEN_REFRESH_WINDOW_SECS=3600

# RBAC & SSO
ENABLE_RBAC=true
ENABLE_SSO=false
SSO_PROVIDER=

# ============================================
# RATE LIMITING
# ============================================
ENABLE_RATE_LIMITING=true
GLOBAL_RPM=60000
GLOBAL_RPS=1000
PER_IP_RPM=600
PER_IP_RPS=10
PER_USER_RPM=1200
RATE_LIMIT_REFILL_SECS=60

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGINS=http://localhost:3000,https://app.example.com
CORS_CREDENTIALS=true
CORS_MAX_AGE_SECS=3600

# ============================================
# REQUEST HANDLING
# ============================================
REQUEST_TIMEOUT_SECS=30
MAX_BODY_SIZE=10485760

# ============================================
# LOGGING & OBSERVABILITY
# ============================================
LOG_LEVEL=info
STRUCTURED_LOGGING=true
LOG_REQUESTS=true
LOG_RETENTION_DAYS=30
ENABLE_TRACING=true

# ============================================
# COMPLIANCE & PRIVACY
# ============================================
ENABLE_DPDP=true
ENABLE_GDPR=true
DATA_RETENTION_DAYS=2555

# ============================================
# VAULT & SECRETS MANAGEMENT
# ============================================
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# ============================================
# EXTERNAL INTEGRATIONS & API KEYS
# ============================================
GEMINI_API_KEY=

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_API_BASE_URL=http://localhost:3001/api/v1
VITE_ENVIRONMENT=production

# ============================================
# FEATURE FLAGS
# ============================================
TEST_MODE=false
ENABLE_COST_ARBITRAGE=true
ENABLE_SEMANTIC_FIREWALL=true
ENABLE_FEDERATED_LEARNING=true

# ============================================
# DEPLOYMENT & ORCHESTRATION
# ============================================
KUBERNETES_NAMESPACE=default
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_TAG=latest
